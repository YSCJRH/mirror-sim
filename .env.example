# Core app settings
MIRROR_ENV=development
MIRROR_DATA_ROOT=data/demo
MIRROR_ARTIFACT_ROOT=artifacts/demo
MIRROR_DEFAULT_SEED=7
MIRROR_ALLOW_UNSAFE_DEMO=0

# Phase 1 public demo defaults.
# Public deployments serve only precomputed deterministic artifacts.
MIRROR_PUBLIC_DEMO_MODE=1
MIRROR_ALLOW_ANONYMOUS_RUNS=0

# Optional private-beta LLM decision-kernel settings.
# Not used by Phase 1 public demo mode.
# Mirror only lets the model choose among legal actions.
# If the model is missing or invalid, the kernel falls back deterministically.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
MIRROR_DECISION_MODEL=

# Hosted private-beta model access. Disabled for Phase 1 public demo.
# Keep real values in local .env or deployment secrets only. Never commit them.
# Do not create a public browser-exposed OpenAI key variable.
MIRROR_HOSTED_MODEL_ENABLED=0
MIRROR_HOSTED_OPENAI_API_KEY=
MIRROR_HOSTED_OPENAI_BASE_URL=https://api.openai.com/v1
MIRROR_HOSTED_DECISION_MODEL=
MIRROR_BETA_ACCESS_CODE=
MIRROR_HOSTED_DAILY_REQUEST_LIMIT=20
MIRROR_HOSTED_SESSION_BRANCH_LIMIT=8
MIRROR_HOSTED_MAX_OUTPUT_TOKENS=512
